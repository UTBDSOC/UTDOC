generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum MemberRole {
  admin
  team_lead
  member
}

enum Team {
  president
  events
  marketing
  finance
  sponsorship
  it
}

enum EventStatus {
  planning
  active
  post_event
  archived
}

enum TaskStatus {
  not_started
  in_progress
  completed
  blocked
}

enum TaskCategory {
  GENERAL
  CONTRACTS_PROPOSALS
  MARKETING
  EVENT_PROGRAM
  DECORATIONS
  FOOD_CATERING
  FINANCE
}

enum NotificationType {
  deadline_approaching
  task_overdue
  eop_warning
  weekly_digest
  task_assigned
  status_change
}

enum NotificationChannel {
  IN_APP
  EMAIL
  DISCORD
}

// ─── Models ─────────────────────────────────────────────────

model Member {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String
  role               MemberRole
  team               Team?
  positionTitle      String?  @map("position_title")
  discordId          String?  @map("discord_id")
  notificationPrefs  Json     @default("{}") @map("notification_prefs")
  availability       Json     @default("{}")
  avatarUrl          String?  @map("avatar_url")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  mainContactEvents  Event[]           @relation("MainContact")
  createdEvents      Event[]           @relation("EventCreator")
  eventMembers       EventMember[]
  assignedTasks      Task[]            @relation("TaskAssignee")
  completedEopItems  EopItem[]         @relation("EopCompletedBy")
  uploadedFiles      EventFile[]       @relation("FileUploader")
  createdMinutes     MeetingMinutes[]  @relation("MinutesCreator")
  notifications      Notification[]    @relation("NotificationRecipient")

  @@map("members")
}

model Event {
  id                  String      @id @default(uuid())
  name                String
  date                DateTime?
  time                String?
  venue               String?
  estimatedAttendance Int?        @map("estimated_attendance")
  status              EventStatus @default(planning)
  description         String?
  mainContactId       String?     @map("main_contact_id")
  mainContactPhone    String?     @map("main_contact_phone")
  createdById         String?     @map("created_by_id")
  collaboratingClubs  String[]    @default([]) @map("collaborating_clubs")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  mainContact         Member?              @relation("MainContact", fields: [mainContactId], references: [id])
  createdBy           Member?              @relation("EventCreator", fields: [createdById], references: [id])
  eventMembers        EventMember[]
  tasks               Task[]
  eopItems            EopItem[]
  files               EventFile[]
  meetingMinutes      MeetingMinutes[]
  interClubAgreements InterClubAgreement[]

  @@index([status])
  @@index([date])
  @@index([mainContactId])
  @@index([createdById])
  @@map("events")
}

model EventMember {
  eventId   String @map("event_id")
  memberId  String @map("member_id")
  eventRole String @default("member") @map("event_role")

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([eventId, memberId])
  @@index([memberId])
  @@map("event_members")
}

model TaskTemplate {
  id           String       @id @default(uuid())
  text         String       @unique
  category     TaskCategory
  defaultTeam  Team?        @map("default_team")
  isEopRelated Boolean      @default(false) @map("is_eop_related")
  sortOrder    Int          @default(0) @map("sort_order")

  tasks Task[]

  @@index([category])
  @@map("task_templates")
}

model Task {
  id          String     @id @default(uuid())
  eventId     String     @map("event_id")
  templateId  String?    @map("template_id")
  text        String
  category    TaskCategory
  status      TaskStatus @default(not_started)
  assigneeId  String?    @map("assignee_id")
  deadline    DateTime?
  notes       String?
  sortOrder   Int        @default(0) @map("sort_order")
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  event    Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template TaskTemplate? @relation(fields: [templateId], references: [id])
  assignee Member?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  files    EventFile[]

  @@index([eventId])
  @@index([assigneeId])
  @@index([status])
  @@index([category])
  @@index([deadline])
  @@map("tasks")
}

model EopItem {
  id          String    @id @default(uuid())
  eventId     String    @map("event_id")
  itemKey     String    @map("item_key")
  label       String
  isRequired  Boolean   @default(true) @map("is_required")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedBy String?   @map("completed_by")
  completedAt DateTime? @map("completed_at")
  fileUrl     String?   @map("file_url")
  fileName    String?   @map("file_name")
  notes       String?

  // Relations
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  completer Member? @relation("EopCompletedBy", fields: [completedBy], references: [id])

  @@unique([eventId, itemKey])
  @@index([eventId])
  @@map("eop_items")
}

model EventFile {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  taskId     String?  @map("task_id")
  uploadedBy String   @map("uploaded_by")
  fileUrl    String   @map("file_url")
  fileName   String   @map("file_name")
  fileType   String?  @map("file_type")
  fileSize   Int?     @map("file_size")
  category   String?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  task     Task?  @relation(fields: [taskId], references: [id])
  uploader Member @relation("FileUploader", fields: [uploadedBy], references: [id])

  @@index([eventId])
  @@index([taskId])
  @@map("event_files")
}

model MeetingMinutes {
  id               String   @id @default(uuid())
  eventId          String   @map("event_id")
  date             DateTime
  attendees        String[]
  apologies        String[]
  agenda           String?
  discussion       String?
  actionItems      Json     @default("[]") @map("action_items")
  nextMeetingFocus String?  @map("next_meeting_focus")
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator Member @relation("MinutesCreator", fields: [createdBy], references: [id])

  @@index([eventId])
  @@map("meeting_minutes")
}

model Notification {
  id            String              @id @default(uuid())
  recipientId   String              @map("recipient_id")
  type          NotificationType
  title         String
  body          String?
  referenceType String?             @map("reference_type")
  referenceId   String?             @map("reference_id")
  channel       NotificationChannel @default(IN_APP)
  isRead        Boolean             @default(false) @map("is_read")
  sentAt        DateTime?           @map("sent_at")
  createdAt     DateTime            @default(now()) @map("created_at")

  // Relations
  recipient Member @relation("NotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([isRead])
  @@map("notifications")
}

model InterClubAgreement {
  id               String   @id @default(uuid())
  eventId          String   @map("event_id")
  partnerClub      String   @map("partner_club")
  agreementDate    DateTime? @map("agreement_date")
  costSplitPct     Float?   @map("cost_split_pct")
  profitSplitPct   Float?   @map("profit_split_pct")
  responsibilities Json     @default("{}")
  fileUrl          String?  @map("file_url")
  notes            String?

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("inter_club_agreements")
}
